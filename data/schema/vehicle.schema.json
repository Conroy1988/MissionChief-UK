{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conroy1988.github.io/MissionChief-UK/schema/vehicle.schema.json",
  "title": "MissionChief UK Vehicle Record",
  "type": "object",
  "required": ["id", "name", "service", "verification"],
  "properties": {
    "id": {"type": ["integer", "string"]},
    "name": {"type": "string", "minLength": 1},
    "aliases": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "service": {"type": "string"},
    "category": {"type": "string"},
    "cost": {"$ref": "#/$defs/costInfo"},
    "staffing": {"$ref": "#/$defs/staffingInfo"},
    "training": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "building_requirements": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "deployment": {"$ref": "#/$defs/deploymentInfo"},
    "notes": {"type": "array", "items": {"type": "string"}},
    "verification": {"$ref": "#/$defs/verification"}
  },
  "$defs": {
    "costInfo": {
      "type": "object",
      "properties": {
        "credits": {"type": "integer", "minimum": 0},
        "coins": {"type": "integer", "minimum": 0}
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "staffingInfo": {
      "type": "object",
      "properties": {
        "minimum": {"type": "integer", "minimum": 0},
        "maximum": {"type": "integer", "minimum": 0},
        "default": {"type": "integer", "minimum": 0},
        "roles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "deploymentInfo": {
      "type": "object",
      "properties": {
        "is_trailer": {"type": "boolean"},
        "operating_environments": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["status", "checked_at"],
      "properties": {
        "status": {"type": "string", "enum": ["verified", "calculated", "community-report", "review-required"]},
        "checked_at": {"type": "string", "format": "date"},
        "sources": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
