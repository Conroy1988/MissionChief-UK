{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conroy1988.github.io/MissionChief-UK/schema/mission.schema.json",
  "title": "MissionChief UK Mission Record",
  "type": "object",
  "required": ["id", "name", "service", "requirements", "verification"],
  "properties": {
    "id": {"type": ["integer", "string"]},
    "name": {"type": "string", "minLength": 1},
    "aliases": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "service": {"type": "string"},
    "mission_types": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "poi": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "duration_minutes": {"type": "integer", "minimum": 1},
    "custom_spawn_area": {"type": "boolean"},
    "restricted_vehicle_types": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "handoff_destinations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "variant": {"$ref": "#/$defs/variantInfo"},
    "preconditions": {
      "type": "object",
      "properties": {
        "fire_stations": {"type": "integer", "minimum": 0},
        "rescue_stations": {"type": "integer", "minimum": 0},
        "police_stations": {"type": "integer", "minimum": 0},
        "recovery_centres": {"type": "integer", "minimum": 0},
        "hart_bases": {"type": "integer", "minimum": 0},
        "gp_surgeries": {"type": "integer", "minimum": 0},
        "police_public_order_extensions": {"type": "integer", "minimum": 0},
        "coastguard_rescue_stations": {"type": "integer", "minimum": 0},
        "lifeboat_stations": {"type": "integer", "minimum": 0},
        "helicopter_hangars": {"type": "integer", "minimum": 0},
        "mud_decontamination_extensions": {"type": "integer", "minimum": 0},
        "hovercraft_extensions": {"type": "integer", "minimum": 0},
        "mountain_rescue_stations": {"type": "integer", "minimum": 0},
        "search_and_rescue_hqs": {"type": "integer", "minimum": 0},
        "active_drones": {"type": "integer", "minimum": 0},
        "other": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "requirements": {
      "type": "object",
      "required": ["guaranteed"],
      "properties": {
        "guaranteed": {"type": "array", "items": {"$ref": "#/$defs/resourceRequirement"}},
        "probabilistic": {"type": "array", "items": {"$ref": "#/$defs/probabilisticRequirement"}},
        "alternatives": {"type": "array", "items": {"$ref": "#/$defs/alternativeResourceRequirement"}}
      },
      "additionalProperties": false
    },
    "personnel": {"$ref": "#/$defs/personnelInfo"},
    "patients": {"$ref": "#/$defs/patientInfo"},
    "prisoners": {"$ref": "#/$defs/prisonerInfo"},
    "reward": {"type": "object"},
    "follow_up_missions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "expandable_missions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "notes": {"type": "array", "items": {"type": "string"}},
    "verification": {"$ref": "#/$defs/verification"}
  },
  "$defs": {
    "resourceRequirement": {
      "type": "object",
      "required": ["resource", "quantity"],
      "properties": {
        "resource": {"type": "string", "minLength": 1},
        "quantity": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "probabilisticRequirement": {
      "type": "object",
      "required": ["resource", "quantity", "probability"],
      "properties": {
        "resource": {"type": "string", "minLength": 1},
        "quantity": {"type": "integer", "minimum": 1},
        "probability": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "alternativeResourceRequirement": {
      "type": "object",
      "required": ["resources", "quantity"],
      "properties": {
        "resources": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 2,
          "uniqueItems": true
        },
        "quantity": {"type": "integer", "minimum": 1},
        "notes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "personnelRequirement": {
      "type": "object",
      "required": ["role", "quantity"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "quantity": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "probabilisticPersonnelRequirement": {
      "type": "object",
      "required": ["role", "quantity", "probability"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "quantity": {"type": "integer", "minimum": 1},
        "probability": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "personnelInfo": {
      "type": "object",
      "properties": {
        "available": {"type": "array", "items": {"$ref": "#/$defs/personnelRequirement"}},
        "required": {"type": "array", "items": {"$ref": "#/$defs/personnelRequirement"}},
        "average_minimum": {"type": "array", "items": {"$ref": "#/$defs/personnelRequirement"}},
        "probabilistic": {"type": "array", "items": {"$ref": "#/$defs/probabilisticPersonnelRequirement"}}
      },
      "additionalProperties": false
    },
    "patientInfo": {
      "type": "object",
      "properties": {
        "minimum": {"type": "integer", "minimum": 0},
        "maximum": {"type": "integer", "minimum": 0},
        "transport_probability": {"type": "number", "minimum": 0, "maximum": 1},
        "critical_care_probability": {"type": "number", "minimum": 0, "maximum": 1},
        "first_responder_full_care_probability": {"type": "number", "minimum": 0, "maximum": 1},
        "specializations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      },
      "additionalProperties": false
    },
    "prisonerInfo": {
      "type": "object",
      "properties": {"maximum": {"type": "integer", "minimum": 0}},
      "additionalProperties": false
    },
    "variantInfo": {
      "type": "object",
      "required": ["source_mission_id", "kind", "key"],
      "properties": {
        "source_mission_id": {"type": ["integer", "string"]},
        "kind": {"type": "string", "enum": ["base", "additive-overlay", "mission-variation"]},
        "key": {"type": "string", "minLength": 1},
        "notes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "required": ["status", "checked_at"],
      "properties": {
        "status": {"type": "string", "enum": ["verified", "calculated", "community-report", "review-required"]},
        "checked_at": {"type": "string", "format": "date"},
        "sources": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}